# GUNZ Node Tracker — Environment Configuration

# Server
PORT=3001
NODE_ENV=development

# MySQL
DATABASE_URL=mysql://root:password@localhost:3306/gunz_tracker

# Redis (optional — falls back to in-memory cache if unavailable)
REDIS_URL=redis://localhost:6379

# GUNZ API
GUNZ_API_BASE=https://api.gunzchain.app/api/v1
GUNZ_API_PAGE_SIZE=10000

# Sync interval in minutes
SYNC_INTERVAL_MINUTES=2

# Cache TTL in seconds
CACHE_TTL_SECONDS=60

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
